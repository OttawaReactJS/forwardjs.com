---
import { Image } from "astro:assets";
import { formatDateTime } from "../../public/scripts/utils";
const {
  id,
  type,
  title,
  dateTime,
  location,
  eventUrl,
  photo,
  rsvpCount,
  rsvpsOpen,
} = Astro.props;
---

<a id={id} href={eventUrl} class="box">
  <div class="row">
    <div class="information">
      <time datetime={dateTime} data-local-datetime>
        📅 {formatDateTime(dateTime)}
      </time>
      <span class="title">{title}</span>
      <div>
        <span>{location}</span>
      </div>
    </div>
    <div>
      {
        photo && (
          <Image
            class="photo"
            src={photo}
            alt="Event photo"
            width="200"
            height="112"
            loading="lazy"
          />
        )
      }
    </div>
  </div>
  <div class="row">
    <div class="attendees">
      <span>{rsvpCount || 0} attendees</span>
    </div>
    {type === "upcoming" && rsvpsOpen && <span class="rsvpButton">Attend</span>}
    {type === "upcoming" && !rsvpsOpen && <span>RSVPs closed</span>}
  </div>
</a>

<script is:inline>
  (() => {
    const localDateFormatter = new Intl.DateTimeFormat(undefined, {
      month: "long",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    });

    document.querySelectorAll("time[data-local-datetime]").forEach((el) => {
      const iso = el.getAttribute("datetime");
      const parsedDate = iso ? new Date(iso) : null;

      if (!parsedDate || Number.isNaN(parsedDate.getTime())) return;

      const currentYear = new Date().getFullYear();
      const options =
        parsedDate.getFullYear() === currentYear
          ? undefined
          : {
              year: "numeric",
              month: "long",
              day: "numeric",
              hour: "numeric",
              minute: "2-digit",
              hour12: true,
            };
      const formatter = options
        ? new Intl.DateTimeFormat(undefined, options)
        : localDateFormatter;

      el.textContent = `📅 ${formatter.format(parsedDate)}`;
    });
  })();
</script>

<style>
  .box {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 1rem;
    border-radius: 8px;
    background-color: #fff;
    box-shadow: rgba(0, 0, 0, 0.04) 0px 3px 5px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.5s ease;
    @media screen and (max-width: 675px) {
      gap: 16px;
    }
  }

  .box:hover {
    box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 15px;
  }

  .row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    @media screen and (max-width: 675px) {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .information {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-self: flex-start;
  }

  .attendees {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .photo {
    width: 200px;
    object-fit: cover;
    border-radius: 8px;
    @media screen and (max-width: 675px) {
      display: none;
    }
  }

  .rsvpButton {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 8px;
    border: 2px solid #008000;
    background-color: #fff;
    color: #008000;
    font-size: 1rem;
    cursor: pointer;
    text-decoration: none !important;
    transition: all 0.2s ease;
  }

  .rsvpButton:hover {
    background-color: #008000;
    color: #fff;
  }

  time {
    font-size: 0.8rem;
    color: #666;
  }

  .title {
    font-weight: 500;
  }
</style>
