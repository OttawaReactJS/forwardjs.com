---
import { getCollection } from "astro:content";
import Meetup from "../components/Meetup.astro";

const pastEvents = await getCollection("pastEvents");
const upcomingEvents = await getCollection("upcomingEvents");
const displayedPastEvents = pastEvents.slice(0, 6);
---

<section id="events">
  <div class="events">
    <h2>Events</h2>
    <p class="events__intro">
      Monthly community meetups in Ottawa featuring talks, demos, and networking
      for developers of all experience levels.
    </p>
    <div class="events__list">
      <h3>Upcoming</h3>
      {
        upcomingEvents.length === 0 && (
          <p class="empty-state">
            Meetups are usually on the third Thursday each month. RSVPs open
            about a week before each event.
          </p>
        )
      }
      {
        upcomingEvents.map((event) => (
          <Meetup
            id={event.id}
            type="upcoming"
            title={event.data.title}
            dateTime={event.data.dateTime}
            location={event.data.location.name}
            address={event.data.location.address}
            photo={event.data.photo}
            eventUrl={event.data.eventUrl}
            rsvpCount={event.data.rsvpCount}
            memberPhotos={event.data.memberPhotos}
            rsvpsOpen={event.data.rsvpsOpen}
          />
        ))
      }
    </div>
    <div class="events__list">
      <h3>Past</h3>
      {pastEvents.length === 0 && <p>No past events</p>}
      {
        displayedPastEvents.map((event) => (
          <Meetup
            id={event.id}
            type="past"
            title={event.data.title}
            dateTime={event.data.dateTime}
            location={event.data.location.name}
            address={event.data.location.address}
            photo={event.data.photo}
            eventUrl={event.data.eventUrl}
            rsvpCount={event.data.rsvpCount}
            memberPhotos={event.data.memberPhotos}
            rsvpsOpen={event.data.rsvpsOpen}
          />
        ))
      }
      <a href="https://www.meetup.com/ottawa-forwardjs-meetup/events/?type=past"
        >View more on Meetup</a
      >
    </div>
  </div>
</section>

<style>
  section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--gray);
    width: 100%;
  }

  .events {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-width: 1005px;
    width: 100%;
    padding: 2.5rem 1rem 3rem;
  }

  .events__intro {
    color: #4c4b51;
  }

  .events__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    margin: 0 auto;
  }

  h2 {
    letter-spacing: 0.02em;
  }

  h3 {
    margin-bottom: 0.25rem;
  }

  .empty-state {
    color: #4c4b51;
  }

  a[href*="meetup.com"] {
    width: fit-content;
    text-underline-offset: 2px;
  }
</style>
