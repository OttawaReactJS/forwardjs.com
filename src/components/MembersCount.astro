---
import meetupStats from "../data/meetupStats.json";
---

<a
  href="https://www.meetup.com/ottawa-forwardjs-meetup/"
  target="_blank"
  rel="noopener"
  class="members-count">{meetupStats.memberCount.toLocaleString()} Members</a
>

<style>
  .members-count {
    font-weight: 600;
  }

  @media (max-width: 1000px) {
    .members-count {
      display: none;
    }
  }
</style>
